{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/extract/?",
      "dest": "/api/index.py"
    },
    {
      "handle": "filesystem"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 300
    },
    "app/api/**/*": {
      "maxDuration": 300
    }
  }
}
